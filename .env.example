SERVER_PORT=5000

# MySQL (Database name is: ast)
DB_HOST=localhost
DB_USER=root
DB_PASS=your_password
DB_DATABASE=ast

# JWT
JWT_SECRET=change_this_to_a_strong_secret
JWT_EXPIRES_IN=7d

# Prokerala Astrology API (set these in your real .env, NEVER commit secrets)
# Obtain from https://api.prokerala.com after creating an app.
PROKERALA_CLIENT_ID=your_client_id_here
PROKERALA_CLIENT_SECRET=your_client_secret_here
# Optionally override token URL if needed
# PROKERALA_TOKEN_URL=https://api.prokerala.com/token

# Each service type maps to a PDF endpoint URL.
# Configure the endpoints you actually use based on Prokerala docs.
# Example (NOT real endpoints, replace with correct ones from Prokerala):
# PROKERALA_KUNDALI_MATCHING_PDF_ENDPOINT=https://api.prokerala.com/v2/astrology/kundli-matching/pdf
# PROKERALA_DAILY_HOROSCOPE_PDF_ENDPOINT=https://api.prokerala.com/v2/astrology/daily-horoscope/pdf
# PROKERALA_MONTHLY_HOROSCOPE_PDF_ENDPOINT=https://api.prokerala.com/v2/astrology/monthly-horoscope/pdf
# PROKERALA_BIRTH_CHART_PDF_ENDPOINT=https://api.prokerala.com/v2/astrology/birth-chart/pdf
# PROKERALA_PANCHANG_PDF_ENDPOINT=https://api.prokerala.com/v2/astrology/panchang/pdf
# PROKERALA_DOSHA_REPORT_PDF_ENDPOINT=https://api.prokerala.com/v2/astrology/dosha-report/pdf

